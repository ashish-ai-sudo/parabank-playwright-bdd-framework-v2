{
  "compilerOptions": {
    // ── Target & Module ────────────────────────────────────────────────────
    // ES2022 gives us top-level await, Array.at(), Object.hasOwn() etc.
    // NodeNext: the non-deprecated module/moduleResolution pair for Node.js.
    // Because package.json has no "type": "module", TypeScript treats every
    // .ts file as CommonJS — behaviour is identical to the old "CommonJS" +
    // "node10" pair, without the TS 5.9 deprecation errors.
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "moduleResolution": "NodeNext",

    // ── Emit ───────────────────────────────────────────────────────────────
    // outDir is here for completeness; the test suite runs via ts-node so
    // no compiled output is ever needed in normal operation.
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // ── Type Safety ────────────────────────────────────────────────────────
    // strict: true enables strictNullChecks, noImplicitAny,
    // strictFunctionTypes and more. Non-negotiable for enterprise code.
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,

    // ── Interoperability ───────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // ── Decorators ─────────────────────────────────────────────────────────
    // Required if you adopt IoC / DI patterns later (e.g. tsyringe, inversify).
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

  },

  // ── ts-node Runtime Configuration ────────────────────────────────────────
  // transpileOnly skips full type-checking at runtime for speed.
  // Type-correctness is enforced separately by `npm run typecheck`.
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },

  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "reports", "test-results"]
}
