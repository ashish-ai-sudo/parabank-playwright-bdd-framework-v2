{
  "name": "parabank-bdd-automation",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright + TypeScript + Cucumber BDD automation for ParaBank",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test":              "cucumber-js",
    "test:smoke":        "cucumber-js --profile smoke",
    "test:regression":   "cucumber-js --profile regression",
    "test:security":     "cucumber-js --profile security",
    "test:accessibility":"cucumber-js --profile accessibility",
    "test:e2e":          "cucumber-js --profile e2e",
    "test:ci":           "cucumber-js --profile ci",

    "test:headed":       "HEADLESS=false cucumber-js",
    "test:firefox":      "BROWSER=firefox cucumber-js",
    "test:safari":       "BROWSER=webkit cucumber-js",
    "test:staging":      "TEST_ENV=staging cucumber-js",
    "test:production":   "TEST_ENV=production cucumber-js",

    "report:html":       "node scripts/generate-report.js",

    "lint":              "eslint 'src/**/*.ts'",
    "lint:fix":          "eslint 'src/**/*.ts' --fix",
    "format":            "prettier --write 'src/**/*.ts' 'features/**/*.feature' '*.json' '*.js'",
    "format:check":      "prettier --check 'src/**/*.ts' 'features/**/*.feature'",
    "typecheck":         "tsc --noEmit",
    "clean":             "rm -rf reports test-results .tmp dist",

    "playwright:install": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "@cucumber/cucumber":              "^10.6.0",
    "@playwright/test":                "^1.44.0",
    "@types/node":                     "^20.12.0",
    "@typescript-eslint/eslint-plugin":"^7.8.0",
    "@typescript-eslint/parser":       "^7.8.0",
    "dotenv":                          "^16.4.5",
    "eslint":                          "^8.57.0",
    "eslint-config-prettier":          "^9.1.0",
    "multiple-cucumber-html-reporter": "^3.6.0",
    "prettier":                        "^3.2.5",
    "tsconfig-paths":                  "^4.2.0",
    "ts-node":                         "^10.9.2",
    "typescript":                      "^5.4.5"
  }
}
