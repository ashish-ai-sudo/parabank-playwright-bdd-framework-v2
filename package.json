{
  "name": "parabank-bdd-automation",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright + TypeScript + Cucumber BDD automation for ParaBank",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:smoke": "node scripts/run-tests.js --profile smoke",
    "test:regression": "node scripts/run-tests.js --profile regression",
    "test:security": "node scripts/run-tests.js --profile security",
    "test:accessibility": "node scripts/run-tests.js --profile accessibility",
    "test:e2e": "node scripts/run-tests.js --profile e2e",
    "test:ci": "node scripts/run-tests.js --profile ci",
    "test:registration": "node scripts/run-tests.js --tags @registration",
    "test:login": "node scripts/run-tests.js --tags @login",
    "test:account": "node scripts/run-tests.js --tags @account",
    "test:headed": "HEADLESS=false node scripts/run-tests.js",
    "test:firefox": "BROWSER=firefox node scripts/run-tests.js",
    "test:safari": "BROWSER=webkit node scripts/run-tests.js",
    "test:staging": "TEST_ENV=staging node scripts/run-tests.js",
    "test:production": "TEST_ENV=production node scripts/run-tests.js",
    "report:html": "node scripts/generate-report.js",
    "report:generate": "allure generate allure-results -o allure-report --clean",
    "report:open": "node scripts/open-report.js",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'features/**/*.feature' '*.json' '*.js'",
    "format:check": "prettier --check 'src/**/*.ts' 'features/**/*.feature'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf reports test-results .tmp dist allure-results allure-report",
    "playwright:install": "npx playwright install --with-deps",
    "test:dryrun": "cucumber-js --dry-run"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cucumber/cucumber": "^10.6.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "allure-commandline": "^2.43.0",
    "allure-cucumberjs": "^3.10.2",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "multiple-cucumber-html-reporter": "^3.6.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
