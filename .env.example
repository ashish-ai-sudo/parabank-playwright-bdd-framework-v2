# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Environment configuration template
#
# Instructions:
#   1. Copy this file:   cp .env.example .env
#   2. Edit .env with your local values
#   3. NEVER commit .env to version control (.gitignore handles this)
#
# For other environments, create .env.staging or .env.production using the
# same keys. Select at runtime with:  TEST_ENV=staging npm test
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
# Full base URL of the application under test.
# Playwright context.baseURL is set to this value so step definitions
# can use relative paths: page.goto('/register.htm')
BASE_URL=https://parabank.parasoft.com

# ── Browser ───────────────────────────────────────────────────────────────────
# Which browser Playwright should launch.
# Accepted values: chromium | firefox | webkit
BROWSER=chromium

# Whether to run the browser in headless mode.
# Set to false for local debugging — browser window will be visible.
# Accepted values: true | false
HEADLESS=true

# Milliseconds to wait between each Playwright action (useful for slow demos).
# Set to 0 to disable.
SLOW_MO=0

# ── Timeouts (milliseconds) ───────────────────────────────────────────────────
# Maximum time to wait for an element to be available / actionable.
DEFAULT_TIMEOUT=30000

# Maximum time to wait for a page navigation to complete.
NAVIGATION_TIMEOUT=60000

# ── Test Behaviour ────────────────────────────────────────────────────────────
# Record a video of each scenario execution.
# Videos are saved to test-results/videos/ and are gitignored.
# Accepted values: true | false
RECORD_VIDEO=false

# Ignore HTTPS certificate errors.
# Set to true when testing against staging environments with self-signed certs.
# Accepted values: true | false
IGNORE_HTTPS_ERRORS=false

# ── Viewport ──────────────────────────────────────────────────────────────────
# Browser window dimensions for each test scenario.
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
